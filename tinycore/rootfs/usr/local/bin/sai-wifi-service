#!/bin/sh

set -eu

IPC_DIR="${SAI_WIFI_IPC_DIR:-/tmp/sai-wifi-ipc}"
STATE_DIR="${SAI_WIFI_STATE_DIR:-/opt/sai-wifi}"
LOG_FILE="${SAI_WIFI_LOG_FILE:-/tmp/sai-wifi-service.log}"

mkdir -p "$IPC_DIR" "$STATE_DIR"
touch "$LOG_FILE"

log() {
    printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo now)" "$*" >> "$LOG_FILE"
}

write_response_file() {
    req_dir="$1"
    name="$2"
    shift 2
    printf '%s' "$*" > "$req_dir/$name"
}

detect_wireless_interface() {
    if [ -f "$STATE_DIR/interface" ]; then
        iface="$(cat "$STATE_DIR/interface" 2>/dev/null || true)"
        if [ -n "$iface" ] && [ -d "/sys/class/net/$iface" ]; then
            printf '%s\n' "$iface"
            return 0
        fi
    fi

    iface="$(iwconfig 2>/dev/null | awk '/IEEE 802\.11/ {print $1; exit}')"
    if [ -z "$iface" ]; then
        iface="$(find /sys/class/net -mindepth 1 -maxdepth 1 -type d -name 'wl*' -exec basename {} \; 2>/dev/null | head -n 1)"
    fi

    if [ -n "$iface" ]; then
        printf '%s\n' "$iface" > "$STATE_DIR/interface"
        printf '%s\n' "$iface"
        return 0
    fi

    return 1
}

current_ip_for_interface() {
    iface="$1"

    ifconfig "$iface" 2>/dev/null | awk '
        /inet addr:/ {
            split($2, a, ":");
            print a[2];
            exit
        }
        /inet / {
            print $2;
            exit
        }
    '
}

current_ssid_for_interface() {
    iface="$1"

    iwconfig "$iface" 2>/dev/null | awk -F 'ESSID:' '
        /ESSID:/ {
            ssid = $2;
            sub(/^"/, "", ssid);
            sub(/".*/, "", ssid);
            if (ssid == "" || ssid == "off/any") {
                exit
            }
            print ssid;
            exit
        }
    '
}

stop_existing_connection() {
    iface="$1"
    pid_file="/var/run/udhcpc.$iface.pid"

    if [ -f "$pid_file" ]; then
        kill "$(cat "$pid_file" 2>/dev/null || true)" >/dev/null 2>&1 || true
        rm -f "$pid_file"
    fi

    pkill -f "wpa_supplicant.*-i$iface" >/dev/null 2>&1 || true
    pkill -f "udhcpc.*$iface" >/dev/null 2>&1 || true
}

render_open_network_conf() {
    conf_path="$1"
    ssid="$2"

    cat > "$conf_path" <<EOF
ctrl_interface=/var/run/wpa_supplicant
update_config=1
network={
    ssid="$ssid"
    key_mgmt=NONE
}
EOF
}

connect_saved_network() {
    iface="$1"
    conf_path="$STATE_DIR/wpa_supplicant.conf"
    pid_file="/var/run/udhcpc.$iface.pid"
    wait_seconds=0

    [ -f "$conf_path" ] || return 1

    stop_existing_connection "$iface"
    ifconfig "$iface" up >/dev/null 2>&1 || true

    if ! wpa_supplicant -B -i "$iface" -c "$conf_path" >> "$LOG_FILE" 2>&1; then
        return 1
    fi

    udhcpc -b -i "$iface" -p "$pid_file" >> "$LOG_FILE" 2>&1 || true

    while [ "$wait_seconds" -lt 20 ]; do
        ip_addr="$(current_ip_for_interface "$iface")"
        if [ -n "$ip_addr" ]; then
            return 0
        fi
        sleep 1
        wait_seconds=$((wait_seconds + 1))
    done

    return 1
}

scan_networks() {
    iface="$1"
    out_file="$2"
    tmp_file="$STATE_DIR/scan.tmp"

    : > "$out_file"

    iwlist "$iface" scan > "$tmp_file" 2>> "$LOG_FILE" || return 1

    awk '
        function flush_record() {
            if (seen && ssid != "") {
                print ssid "\t" security "\t" signal
            }
        }
        /Cell [0-9]+ - Address:/ {
            flush_record()
            ssid=""
            security="secured"
            signal="?"
            seen=1
            next
        }
        /Encryption key:/ {
            split($0, a, ":")
            security = (a[2] ~ /off/) ? "open" : "secured"
            next
        }
        /Quality=/ {
            if (match($0, /Quality=([0-9]+\/[0-9]+)/)) {
                signal = substr($0, RSTART + 8, RLENGTH - 8)
            } else if (match($0, /Signal level=[^ ]+/)) {
                signal = substr($0, RSTART + 13, RLENGTH - 13)
            }
            next
        }
        /ESSID:/ {
            ssid = $0
            sub(/^.*ESSID:"/, "", ssid)
            sub(/".*$/, "", ssid)
            next
        }
        END {
            flush_record()
        }
    ' "$tmp_file" | awk -F '\t' 'length($1) > 0 && !seen[$1]++ { print }' > "$out_file"
}

write_status_response() {
    req_dir="$1"
    iface="$2"
    ssid=""
    ip_addr=""
    connected="no"

    if [ -n "$iface" ]; then
        ssid="$(current_ssid_for_interface "$iface")"
        ip_addr="$(current_ip_for_interface "$iface")"
        if [ -n "$ssid" ]; then
            connected="yes"
        fi
    fi

    write_response_file "$req_dir" status ok
    write_response_file "$req_dir" interface "$iface"
    write_response_file "$req_dir" connected "$connected"
    write_response_file "$req_dir" current_ssid "$ssid"
    write_response_file "$req_dir" ip_address "$ip_addr"
    if [ "$connected" = "yes" ]; then
        write_response_file "$req_dir" message "Wi-Fi is connected."
    else
        write_response_file "$req_dir" message "Wi-Fi is not connected."
    fi
}

process_request() {
    req_dir="$1"
    command_file="$req_dir/command"
    command=""
    iface=""

    [ -f "$command_file" ] || return 0
    command="$(cat "$command_file" 2>/dev/null || true)"

    iface="$(detect_wireless_interface || true)"
    if [ -n "$iface" ]; then
        write_response_file "$req_dir" interface "$iface"
    fi

    case "$command" in
        status)
            if [ -z "$iface" ]; then
                write_response_file "$req_dir" status error
                write_response_file "$req_dir" message "No wireless interface was detected."
            else
                write_status_response "$req_dir" "$iface"
            fi
            ;;
        scan)
            if [ -z "$iface" ]; then
                write_response_file "$req_dir" status error
                write_response_file "$req_dir" message "No wireless interface was detected."
            elif scan_networks "$iface" "$req_dir/scan.tsv"; then
                write_response_file "$req_dir" status ok
                if [ -s "$req_dir/scan.tsv" ]; then
                    write_response_file "$req_dir" message "Available Wi-Fi networks loaded."
                else
                    write_response_file "$req_dir" message "No Wi-Fi networks were found."
                fi
            else
                write_response_file "$req_dir" status error
                write_response_file "$req_dir" message "Wi-Fi scan failed."
            fi
            ;;
        connect)
            if [ -z "$iface" ]; then
                write_response_file "$req_dir" status error
                write_response_file "$req_dir" message "No wireless interface was detected."
            else
                ssid="$(cat "$req_dir/ssid" 2>/dev/null || true)"
                password="$(cat "$req_dir/password" 2>/dev/null || true)"
                conf_path="$STATE_DIR/wpa_supplicant.conf"

                if [ -z "$ssid" ]; then
                    write_response_file "$req_dir" status error
                    write_response_file "$req_dir" message "A Wi-Fi network name is required."
                else
                    if [ -n "$password" ]; then
                        wpa_passphrase "$ssid" "$password" > "$conf_path"
                    else
                        render_open_network_conf "$conf_path" "$ssid"
                    fi
                    chmod 600 "$conf_path"
                    printf '%s\n' "$ssid" > "$STATE_DIR/last_ssid"

                    if connect_saved_network "$iface"; then
                        write_response_file "$req_dir" status ok
                        write_response_file "$req_dir" message "Connected to $ssid."
                        write_response_file "$req_dir" connected yes
                        write_response_file "$req_dir" current_ssid "$ssid"
                        write_response_file "$req_dir" ip_address "$(current_ip_for_interface "$iface")"
                    else
                        write_response_file "$req_dir" status error
                        write_response_file "$req_dir" message "Failed to connect to $ssid."
                    fi
                fi
            fi
            ;;
        disconnect)
            if [ -z "$iface" ]; then
                write_response_file "$req_dir" status error
                write_response_file "$req_dir" message "No wireless interface was detected."
            else
                stop_existing_connection "$iface"
                write_response_file "$req_dir" status ok
                write_response_file "$req_dir" connected no
                write_response_file "$req_dir" current_ssid ""
                write_response_file "$req_dir" ip_address ""
                write_response_file "$req_dir" message "Wi-Fi disconnected."
            fi
            ;;
        *)
            write_response_file "$req_dir" status error
            write_response_file "$req_dir" message "Unsupported Wi-Fi request."
            ;;
    esac

    : > "$req_dir/done"
}

auto_connect_if_possible() {
    iface="$(detect_wireless_interface || true)"

    if [ -z "$iface" ]; then
        log "No wireless interface detected during startup."
        return 0
    fi

    if [ -f "$STATE_DIR/wpa_supplicant.conf" ]; then
        log "Attempting automatic Wi-Fi reconnect on $iface."
        if connect_saved_network "$iface"; then
            log "Automatic Wi-Fi reconnect succeeded on $iface."
        else
            log "Automatic Wi-Fi reconnect failed on $iface."
        fi
    fi
}

auto_connect_if_possible
log "Wi-Fi service started."

while :; do
    found_request=0
    for req_dir in "$IPC_DIR"/req-*; do
        [ -d "$req_dir" ] || continue
        [ -f "$req_dir/done" ] && continue
        found_request=1
        process_request "$req_dir"
    done

    if [ "$found_request" -eq 0 ]; then
        sleep 1
    fi
done
